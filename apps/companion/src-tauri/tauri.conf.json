{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mystia-steward-companion",
  "version": "1.0.0",
  "identifier": "com.tyukki.mystia-steward-companion",
  "build": {
    "beforeDevCommand": "corepack pnpm --dir ../.. dev -- --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173/",
    "beforeBuildCommand": "corepack pnpm --dir ../.. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mystia-steward-companion",
        "url": "/",
        "width": 1040,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
